# Copy to ~/.config/worklog/.env (or the project .env) and fill in.
# All vars are optional — missing ones just disable that collector/sync.

# GitHub — PAT with `repo` scope (classic) or fine-grained with Contents:Read + PRs:Read
WORKLOG_GITHUB_TOKEN=
WORKLOG_GITHUB_USER=TomasPalsson

# Jira Cloud (same token works for Tempo if you use Tempo Cloud)
WORKLOG_JIRA_BASE_URL=https://your-org.atlassian.net
WORKLOG_JIRA_EMAIL=you@example.com
WORKLOG_JIRA_TOKEN=

# Tempo Cloud — generate at https://<org>.atlassian.net → Tempo → Settings → API Integration
WORKLOG_TEMPO_TOKEN=
WORKLOG_TEMPO_BASE_URL=https://api.tempo.io/4

# Google Calendar — put OAuth client JSON at ~/.config/worklog/google_credentials.json
# (GCP → APIs & Services → Credentials → OAuth client ID → Desktop app)
# WORKLOG_GOOGLE_CALENDARS accepts JSON: '["primary", "work@company.com"]'
